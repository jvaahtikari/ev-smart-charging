                "opposite": true,
                "min": 0,
                "max": 1
              }
            ]
          },
          "series": [
            {
              "name": "Price (EUR/kWh)",
              "type": "line",
              "stroke_width": 2,
              "yaxis_id": "first",
              "data_generator": "const ent = hass.states['sensor.ev_price_slots_15m_effective']; const arr = ent?.attributes?.data || []; if (!Array.isArray(arr) || arr.length === 0) return []; return arr\n  .map(it => {\n    const t = Number(it.ts) * 1000;\n    const v = Number(it.PriceWithTax);\n    if (!Number.isFinite(t) || !Number.isFinite(v)) return null;\n    return [t, v];\n  })\n  .filter(Boolean)\n  .sort((a,b)=>a[0]-b[0]);\n"
            },
            {
              "name": "Planned slots",
              "type": "column",
              "yaxis_id": "second",
              "stroke_width": 0,
              "data_generator": "const plan = hass.states['sensor.ev_plan_15m_rank_effective']; const slots = plan?.attributes?.planned_slots || []; if (!Array.isArray(slots) || slots.length === 0) return []; return slots\n  .map(s => Number(s.ts))\n  .filter(ts => Number.isFinite(ts) && ts > 0)\n  .map(ts => [ts*1000, 1])\n  .sort((a,b)=>a[0]-b[0]);\n"
            }
          ]
