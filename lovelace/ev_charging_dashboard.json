            {
              "entity": "sensor.nordpool_predict_fi_price",
              "name": "Ennuste",
              "type": "line",
              "yaxis_id": "price",
              "curve": "straight",
              "stroke_width": 1,
              "stroke_dash": 3,
              "color": "red",
              "opacity": 1,
              "extend_to": false,
              "data_generator": "const fs = hass.states['sensor.nordpool_predict_fi_price']?.attributes?.forecast_start;\nconst x = fs ? Date.parse(fs) : NaN;\nif (!Number.isFinite(x)) return [];\nconst data = entity.attributes.forecast || [];\nlet min = Infinity, max = -Infinity;\nfor (const i of data) {\n  const v = Number(i.value);\n  if (Number.isFinite(v)) { if (v < min) min = v; if (v > max) max = v; }\n}\nif (!Number.isFinite(min) || !Number.isFinite(max)) { min = 0; max = 1; }\n// Add a null point at x+1 ms to stop the path from continuing horizontally.\nreturn [[x, min], [x, max], [x + 1, null]];\n",
              "show": {
                "in_chart": true,
                "in_header": false,
                "in_legend": false,
                "legend_value": false
